{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/form9/generate.ts": {
      "includeFiles": "api/form9/Form9-template.pdf"
    }
  },
  "crons": [
    {
      "path": "/api/email/poll-inbox",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
