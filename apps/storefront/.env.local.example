# Clerk — from clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# OpenRouter — openrouter.ai → Keys (server-side only, never exposed to browser)
OPENROUTER_API_KEY=sk-or-v1-...

# API Worker (Cloudflare Workers)
NEXT_PUBLIC_API_URL=https://oconner-api.your-account.workers.dev

# Admin & Driver app URLs (for staff shortcut bar)
NEXT_PUBLIC_ADMIN_URL=https://admin.oconnoragriculture.com.au
NEXT_PUBLIC_DRIVER_URL=https://driver.oconnoragriculture.com.au

# Stripe — from stripe.com → Developers → API keys (publishable key only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Web Push — VAPID public key (from apps/api VAPID_PUBLIC_KEY secret)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
