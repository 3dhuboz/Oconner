# ─── Clerk Authentication ─────────────────────────────────────────────────────
# From clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_live_...

# ─── Cloudflare ───────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_BUCKET_NAME=butcher-media
KV_NAMESPACE_ID=

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=          # server-side only, never exposed to browser

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=orders@oconnoragriculture.com.au

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── AI / Image Generation ───────────────────────────────────────────────────
OPENROUTER_API_KEY=           # optional, falls back to Cloudflare AI
ZERNIO_API_KEY=               # Facebook reels API

# ─── App URLs ─────────────────────────────────────────────────────────────────
STOREFRONT_URL=https://www.oconnoragriculture.com.au
ADMIN_URL=https://admin.oconnoragriculture.com.au
DRIVER_APP_URL=https://driver.oconnoragriculture.com.au
API_URL=https://oconner-api.your-account.workers.dev
