# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Configuration - From your Firebase project settings
# Use VITE_FB_API_KEY if VITE_FIREBASE_API_KEY is restricted by your platform
VITE_FB_API_KEY=""
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# GMAIL POLLING - Auto-create jobs from emails received at your Gmail inbox
# The app polls this Gmail inbox every 5 minutes (via Vercel Cron) for new work orders
# Setup: Enable Gmail API, create OAuth2 credentials, then get a refresh token
# Guide: https://developers.google.com/gmail/api/quickstart/nodejs
GMAIL_ADDRESS="steve061278@gmail.com"
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

# CRON_SECRET - Secures the Vercel Cron endpoint from unauthorized triggers
# Generate any random string: openssl rand -hex 32
CRON_SECRET=""

# CLOUDMAILIN - Alternative: Email-to-Job via webhook (instead of Gmail polling)
# Sign up at https://www.cloudmailin.com/ to get your email address
# Configure webhook URL to: https://your-app.vercel.app/api/webhooks/email
VITE_CLOUDMAILIN_EMAIL=""

# WEBHOOK AUTH - Firebase user account for server-side Firestore writes
# Create a user in Firebase Auth, or enable Anonymous auth in Firebase Console
WEBHOOK_AUTH_EMAIL=""
WEBHOOK_AUTH_PASSWORD=""

# OPENAI - AI-powered email data extraction (optional, enhances email parsing)
# Get from: https://platform.openai.com/api-keys
# Uses gpt-4o-mini (~$0.001 per email) to extract tenant name, phone, address, issue
OPENAI_API_KEY=""

# GOOGLE MAPS - Live technician tracking, address geocoding, navigation
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API, Places API
VITE_GOOGLE_MAPS_API_KEY=""

# XERO INTEGRATION
# Get these from https://developer.xero.com/myapps/
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# TWILIO SMS INTEGRATION
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# STRIPE PAYMENTS INTEGRATION
VITE_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (create these products in Stripe Dashboard)
# Pricing: $1500 setup + $79/month base (1 admin + 1 tech) + $10/month per additional tech
STRIPE_SETUP_FEE_PRICE_ID=""
STRIPE_BASE_SUBSCRIPTION_PRICE_ID=""
STRIPE_ADDITIONAL_TECH_PRICE_ID=""
