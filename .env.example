# ── Clerk Authentication ─────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com/ > Your app > API Keys
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ── Application URL ─────────────────────────────────────────────────
# Used for Xero OAuth callbacks and self-referential links
APP_URL="http://localhost:3000"

# ── Gmail Polling (auto-create jobs from emails) ────────────────────────
# Setup: Enable Gmail API, create OAuth2 credentials, then get a refresh token
# Guide: https://developers.google.com/gmail/api/quickstart/nodejs
GMAIL_ADDRESS="jobs@example.com"
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

# ── Cron security ─────────────────────────────────────────────────
# Secures /api/email/poll-inbox from unauthorized triggers
# Generate: openssl rand -hex 32
CRON_SECRET=""

# ── OpenRouter AI (email parsing + AI features) ───────────────────────
# Get key at: https://openrouter.ai/keys
# Optional: without it, email parsing falls back to regex-only
OPENROUTER_API_KEY=""

# GOOGLE MAPS - Live technician tracking, address geocoding, navigation
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API, Places API
VITE_GOOGLE_MAPS_API_KEY=""

# XERO INTEGRATION
# Get these from https://developer.xero.com/myapps/
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# R2 PUBLIC URL (for serving uploaded files)
# Enable public access on the R2 bucket, then paste the URL here: https://pub-<hash>.r2.dev
R2_PUBLIC_URL=""

# RESEND EMAIL (transactional notifications to tenants)
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="jobs@wireznrus.com.au"

# TWILIO SMS INTEGRATION
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# STRIPE PAYMENTS INTEGRATION
VITE_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (create these products in Stripe Dashboard)
# Pricing: $1500 setup + $79/month base (1 admin + 1 tech) + $10/month per additional tech
STRIPE_SETUP_FEE_PRICE_ID=""
STRIPE_BASE_SUBSCRIPTION_PRICE_ID=""
STRIPE_ADDITIONAL_TECH_PRICE_ID=""
