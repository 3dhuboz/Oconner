# ─── Clerk Authentication ──────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# ─── Cloudflare ────────────────────────────────────────────────
# D1 database and R2 storage are configured in wrangler.toml
# Worker URL (for frontend API calls in production)
VITE_API_URL=""

# ─── Google Maps ───────────────────────────────────────────────
# Enable: Maps JavaScript API, Geocoding API, Places API
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=""

# ─── Stripe Payments ──────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SETUP_FEE_PRICE_ID=""
STRIPE_BASE_SUBSCRIPTION_PRICE_ID=""
STRIPE_ADDITIONAL_TECH_PRICE_ID=""

# ─── Twilio SMS ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── Xero Accounting ─────────────────────────────────────────
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# ─── OpenRouter (AI email parsing) ────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# ─── Resend (outbound email) ─────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# ─── Gmail Polling (inbound work order emails) ────────────────
# OAuth2 credentials for reading the jobs inbox
GMAIL_ADDRESS=""
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
